# Database connection URL
# Local dev (default): SQLite — no setup needed
# Production: PostgreSQL — get URL from Neon/Koyeb
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./huddleboard.db

# Allowed CORS origins (comma-separated)
# Local dev: Vite dev server
# Production: your Netlify domain
CORS_ORIGINS=http://localhost:5173

# How often to clean up expired boards (in minutes)
TTL_CLEANUP_INTERVAL_MINUTES=15

# Rate limiter storage backend
# Local dev (default): in-memory
# Production (optional): Redis for persistence across restarts
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379
RATE_LIMIT_STORAGE_URI=memory://
